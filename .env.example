# ===================================

# Fintra API - Environment Variables

# ===================================

# Copy this file to `.env` and replace the placeholder values.

# ===================================

# Database Configuration

# ===================================

# Format:

# postgresql://USER:PASSWORD@HOST:PORT/DATABASE

POSTGRES_USER=DB_USER
POSTGRES_PASSWORD=DB_PASSWORD
POSTGRES_DB=DB

DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@localhost:5432/DB

# Production example with SSL:

# DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/fintra_db?sslmode=require

# ===================================

# Application Configuration

# ===================================

NODE_ENV=development
API_PORT=3000

# ===================================

# JWT Configuration

# ===================================

# Generate secure secrets using:

# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_STRING
JWT_REFRESH_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_STRING

# Token expiry time (seconds)

JWT_ACCESS_EXPIRY=900       # 15 minutes
JWT_REFRESH_EXPIRY=604800   # 7 days

# ===================================

# CORS Configuration

# ===================================

# Comma-separated list of allowed origins

ALLOWED_ORIGINS=[http://localhost:3000,http://localhost:5173](http://localhost:3000,http://localhost:5173)

# ===================================

# Logging Configuration

# ===================================

# Options: error | warn | info | http | debug

LOG_LEVEL=debug

# ===================================

# Rate Limiting

# ===================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===================================

# Production Notes

# ===================================

# In production you should:

# - Set NODE_ENV=production

# - Use strong randomly generated JWT secrets

# - Use a secure DATABASE_URL with SSL enabled

# - Restrict ALLOWED_ORIGINS to your frontend domain

# - Set LOG_LEVEL=info or warn
